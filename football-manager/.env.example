# ─── Manager FDF — variables de entorno ──────────────────────────────────────
# Copia a .env y rellena los valores reales antes de levantar docker compose.
# NUNCA commitees .env: está en .gitignore; usa solo placeholders en este archivo.

# ─── Modo ────────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production

# ─── Auth ────────────────────────────────────────────────────────────────────
# OBLIGATORIO. Mínimo 32 caracteres aleatorios. En prod, usa un secreto largo.
# Genera uno: `openssl rand -hex 32`
JWT_SECRET=cambia_esto_por_un_secreto_largo_de_al_menos_32_caracteres
JWT_EXPIRES_IN=30d

# ─── Base de datos ───────────────────────────────────────────────────────────
# Desarrollo local con SQLite (rápido, cero setup):
#   DATABASE_URL=file:./dev.db
# Desarrollo / producción con Postgres (recomendado, el que arranca docker compose):
# Sustituye CHANGE_ME por la misma contraseña que pongas en POSTGRES_PASSWORD.
DATABASE_URL=postgresql://fdf:CHANGE_ME@postgres:5432/managerfdf?schema=public
DIRECT_URL=postgresql://fdf:CHANGE_ME@postgres:5432/managerfdf?schema=public

# Credenciales Postgres (las consume el servicio postgres del compose)
POSTGRES_USER=fdf
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=managerfdf

# ─── Redis (cola de turnos, cache, pub/sub para WebSockets) ──────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ─── Cuentas staff iniciales ─────────────────────────────────────────────────
# Solo se crean si faltan y si existe la contraseña. En producción no hay defaults.
MASTER_PASSWORD=
ADMIN_PASSWORD=
FIFA_PASSWORD=
DEMO_PASSWORD=
RUN_DB_SEED=false
ENSURE_STAFF_ROLES=false

# ─── Motor de turnos ─────────────────────────────────────────────────────────
# Dos turnos diarios por defecto: 11:00 y 23:00 (cron con TZ del contenedor).
TICK_CRON_T1=0 11 * * *
TICK_CRON_T2=0 23 * * *
TZ=Europe/Madrid

# Si quieres desactivar el tick automático en desarrollo (lo lanzas manual desde /admin):
TICK_ENABLED=true

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# ─── Motor de partido (Python) ───────────────────────────────────────────────
# URL del microservicio FastAPI que simula los partidos. En docker compose es
# http://engine:8000. Si se deja vacío o el servicio no responde, el backend
# usa su motor TS de respaldo automáticamente.
ENGINE_URL=http://engine:8000
# En producción con motor público (Fly.io), define la misma clave en engine y backend:
# ENGINE_API_KEY=$(openssl rand -hex 32)
# ENGINE_TIMEOUT_MS=5000

# ─── Frontend ────────────────────────────────────────────────────────────────
# Lo lee Vite en build/dev. En prod sirve el backend, así que basta /api.
VITE_API_URL=http://localhost:8081/api

# ─── Push web ────────────────────────────────────────────────────────────────
# Genera claves VAPID con: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@managerfdf.local

# ─── Logger ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # trace | debug | info | warn | error
