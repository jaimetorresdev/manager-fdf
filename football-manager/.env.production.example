# ─── Manager FDF — variables de PRODUCCIÓN (issue 7.2) ────────────────────────
# Plantilla para el despliegue serverless 0€ (ver docs/DESPLIEGUE.md).
# Cada bloque se configura EN SU PLATAFORMA (no hay un único .env en prod):
#   API → Koyeb (variables del servicio) · Frontend → Vercel (Environment Variables)
#   Motor → Fly.io (fly.toml [env] / fly secrets) · BD → Neon · Redis → Upstash

# ════════ API Fastify (Koyeb) ═════════════════════════════════════════════════
NODE_ENV=production
API_PORT=3001

# OBLIGATORIO: genera uno nuevo SOLO para producción → openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Staff bootstrap: solo activar de forma explícita en un arranque controlado.
MASTER_PASSWORD=
ADMIN_PASSWORD=
FIFA_PASSWORD=
DEMO_PASSWORD=
RUN_DB_SEED=false
ENSURE_STAFF_ROLES=false

# Neon.tech → cadena POOLED (la app) — termina en -pooler y lleva sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/managerfdf?sslmode=require
# Cadena DIRECTA (solo migraciones/seed, prisma migrate deploy). La usa Antigravity (7.x).
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/managerfdf?sslmode=require

# Upstash Redis → usa la URL TLS (rediss://)
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379
# Solo si usas el docker-compose de producción con Redis local:
REDIS_PASSWORD=

# Motor de partido en Fly.io (con fallback automático al motor TS si no responde)
ENGINE_URL=https://managerfdf-engine.fly.dev
ENGINE_TIMEOUT_MS=8000   # margen para el cold start de Fly (auto_stop)
# OBLIGATORIO en prod: misma clave en Fly (`fly secrets set ENGINE_API_KEY=...`) y aquí.
# Genera: openssl rand -hex 32
ENGINE_API_KEY=
# Presupuesto POR PARTIDO del lote /simulate-batch (R7). Subir si el motor va
# justo de CPU y los lotes caducan (el tick reintenta UNA vez con x2 antes de
# caer a simulación individual).
ENGINE_BATCH_MS_PER_MATCH=250

# Turnos 11:00/23:00 Madrid. En Koyeb el contenedor vive 24/7 → el cron interno vale.
TICK_ENABLED=true
TICK_CRON_T1=0 11 * * *
TICK_CRON_T2=0 23 * * *
TZ=Europe/Madrid

# ── Z3 · 7.3 Turno blindado (QStash → POST /api/tick/enqueue → cola Redis → worker)
# off (por defecto): todo como hoy, el cron interno ejecuta el tick directamente.
# on: el cron interno ENCOLA y el worker procesa con reintentos idempotentes +
#     DLQ; QStash puede disparar el mismo endpoint (dedupe por slot/día evita
#     dobles). Requiere REDIS_URL. Ver docs/DESPLIEGUE.md §7.3.
TICK_QUEUE=off
# OBLIGATORIO con TICK_QUEUE=on: secreto del webhook → openssl rand -hex 32
# QStash debe enviarlo como header: Upstash-Forward-x-tick-key: <valor>
TICK_WEBHOOK_SECRET=
# Reintentos antes de aparcar el turno en la DLQ (tick:dlq) y backoff base (ms).
TICK_QUEUE_MAX_ATTEMPTS=3
TICK_QUEUE_RETRY_MS=30000
# TTL del lock entre workers (segundos); cubre el tick más largo esperado.
TICK_QUEUE_LOCK_TTL_S=1800

# Dominio(s) reales del frontend en Vercel, separados por coma. SIN barra final.
CORS_ORIGINS=https://managerfdf.vercel.app

# Web Push (VAPID). Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@managerfdf.com

LOG_LEVEL=info

# ════════ Frontend (Vercel → Environment Variables, scope Production) ════════
# URL pública de la API en Koyeb + /api. El WS se deriva de aquí (https→wss).
VITE_API_URL=https://managerfdf-api.koyeb.app/api

# ════════ Motor (Fly.io) ══════════════════════════════════════════════════════
# OBLIGATORIO si el servicio es público: fly secrets set ENGINE_API_KEY=$(openssl rand -hex 32)
# Debe coincidir con ENGINE_API_KEY del backend en Koyeb.
# TZ va en fly.toml.
