}

model DraftPick {
  id         Int     @id @default(autoincrement())
  draftId    Int
  draft      Draft   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  clubId     Int?
  club       Club?   @relation(fields: [clubId], references: [id], onDelete: SetNull)
  playerId   Int?
  player     Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  round      Int
  pickNumber Int

  // AUDIT H-26: integridad del draft. Cada turno de pick es único por draft, y un
  // mismo jugador no puede ser elegido dos veces en el mismo draft (idempotencia de
  // makePick / reintentos del tick). playerId nullable: Postgres permite múltiples
  // NULL en un unique, así que los picks aún sin asignar no colisionan.
  @@unique([draftId, pickNumber])
  @@unique([draftId, playerId])
  @@index([draftId])  // AUDIT H-30: índice FK
  @@index([clubId])  // AUDIT H-30: índice FK
  @@index([playerId])  // AUDIT H-30: índice FK
}

