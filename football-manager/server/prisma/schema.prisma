model ShareTransaction {
  id            Int       @id @default(autoincrement())
  clubId        Int
  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  ownerId       Int
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade) // AUDIT H-28
  type          String // buy | sell
  shares        Int
  pct           Float
  pricePerShare Float
  grossAmount   Float
  inGameDate    DateTime?
  createdAt     DateTime  @default(now())

  @@index([ownerId, createdAt])
  @@index([clubId, createdAt])
}

model PrivateMessage {
  id        Int      @id @default(autoincrement())
  fromId    Int
  toId      Int
  subject   String
  body      String
  timestamp DateTime @default(now())
  read      Boolean  @default(false)
}

model ScoutAssignment {
  id             Int         @id @default(autoincrement())
  scoutStaffId   Int
  scoutStaff     StaffMember @relation(fields: [scoutStaffId], references: [id], onDelete: Cascade)
  clubTargetId   Int
  clubTarget     Club        @relation(fields: [clubTargetId], references: [id])
