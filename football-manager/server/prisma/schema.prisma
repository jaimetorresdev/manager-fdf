  managerId Int
  manager   Manager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  clubId    Int
  club      Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  objective String
  season    String
  @@index([managerId])  // AUDIT H-30: índice FK (Postgres no los crea solo)
  @@index([clubId])  // AUDIT H-30: índice FK (Postgres no los crea solo)
}

model NationalTeam {
  id                Int               @id @default(autoincrement())
  countryId         Int               @unique
  country           Country           @relation(fields: [countryId], references: [id])
  managerSelectorId Int?              @unique
  managerSelector   Manager?          @relation(fields: [managerSelectorId], references: [id], onDelete: SetNull)
  selectorCalls     SelectorCall[]
  rankingPoints     Int               @default(1000)
  callUps           CallUp[]
  rankingHistory    NationalRanking[]
}

model SelectorCall {
  id             Int          @id @default(autoincrement())
  nationalTeamId Int
  nationalTeam   NationalTeam @relation(fields: [nationalTeamId], references: [id])
  playerId       Int
  player         Player       @relation(fields: [playerId], references: [id])
  match          String

  @@unique([nationalTeamId, playerId])
}

model Tournament {
  id   Int    @id @default(autoincrement())
  name String
  type String // Mundial, Eurocopa, Champions...
}

model Friendly {
  id       Int      @id @default(autoincrement())
  clubAId  Int
  clubBId  Int
  dateTurn DateTime
  incomeA  Float    @default(0)
  incomeB  Float    @default(0)
  result   String?
}

model ChatChannel {
  id       Int           @id @default(autoincrement())
  name     String
  // AUDIT 5.1: antes `type` era `@unique`, impidiendo dos canales del mismo tipo (p. ej.
  // un solo chat de liga para TODAS las ligas). Se separa el `type` del `scopeId` (id de
  // la entidad a la que pertenece el canal: liga, federación, club…) y la unicidad pasa a
  // ser el par `[type, scopeId]`. `scopeId` nullable conserva los canales globales únicos
  // existentes (`[type, null]`), por lo que el cambio es retrocompatible.
  type     String
  scopeId  Int?
  messages ChatMessage[]

  @@unique([type, scopeId])
}

model ChatMessage {
  id           Int            @id @default(autoincrement())
  channelId    Int
  channel      ChatChannel    @relation(fields: [channelId], references: [id])
  authorId     Int
  text         String
  timestamp    DateTime       @default(now())
  mentionsJson String?
  reactions    ChatReaction[]
}

model ChatReaction {
  id        Int         @id @default(autoincrement())
  messageId Int
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model SocialClub {
