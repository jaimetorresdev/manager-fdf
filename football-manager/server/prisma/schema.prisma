// ─── CONTRATOS Carril 2 (esquema añadido por Carril 1) ───────────────────────────

// AUDIT 2.8 / H-20 — idempotencia del tick. `TickRun` registra cada turno procesado
// (único por turno) y `TickStep` cada paso aditivo dentro del turno, para que un
// reintento tras crash NO vuelva a ejecutar healFitness/staff/training/scouting/etc.
// Carril 2 consulta/inserta estas filas para hacer los pasos aditivos idempotentes.
model TickRun {
  id          Int        @id @default(autoincrement())
  turn        Int        @unique // turno de GameState procesado (idempotencia)
  seasonId    Int?
  inGameDate  DateTime?
  status      String     @default("running") // running | completed | failed
  startedAt   DateTime   @default(now())
  finishedAt  DateTime?
  steps       TickStep[]
  @@index([status])
}

model TickStep {
  id        Int      @id @default(autoincrement())
  tickRunId Int
  tickRun   TickRun  @relation(fields: [tickRunId], references: [id], onDelete: Cascade)
  step      String   // healFitness | staffEffects | training | scouting | worldEconomy | ...
  status    String   @default("done") // done | failed
  createdAt DateTime @default(now())
  @@unique([tickRunId, step]) // un paso aditivo se aplica una sola vez por turno
  @@index([tickRunId])
}

// AUDIT manual §4 — "Lupa": inspección especial de un jugador (1/turno) que revela
// atributos no-máximos. Carril 2 implementa la mecánica; Carril 1 aporta el modelo.
model PlayerSpecialInspection {
  id         Int      @id @default(autoincrement())
  playerId   Int
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubId     Int
  turn       Int      // turno en que se usó la lupa (límite 1/turno por club)
  revealed   String?  // JSON: atributos revelados
  createdAt  DateTime @default(now())
  @@index([playerId])
  @@index([clubId, turn])
}
