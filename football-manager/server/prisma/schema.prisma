// QW-20 (BLOQUE Q · 11 jun 2026): misiones semanales generadas en el tick
// (3/semana in-game por mánager humano), evaluadas al cerrar jornada y con
// claim automático. Recompensa SOLO XP/prestigio (cero dinero, cero P2W).
model WeeklyMission {
  id             Int      @id @default(autoincrement())
  managerId      Int
  manager        Manager  @relation(fields: [managerId], references: [id])
  seasonId       Int?
  weekKey        String // "s13-w7"
  type           String // clean_sheet | academy_minutes | renew_contract | sign_u23 | beat_direct_rival | win_next
  title          String
  description    String
  target         Int      @default(1)
  progress       Int      @default(0)
  status         String   @default("pending") // pending | claimed | expired
  rewardXp       Int      @default(50)
  rewardPrestige Int      @default(1)
  baseline       String? // JSON: contexto al generarla (inGameDate, rivalClubId…)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([managerId, weekKey, type])
  @@index([managerId, status])
}

