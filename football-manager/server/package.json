{
  "name": "football-manager-api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node dist/db/seed.js",
    "db:seed:dev": "ts-node src/db/seed.ts",
    "db:ensure-roles": "node dist/db/ensure-roles.js",
    "db:ensure-roles:dev": "ts-node src/db/ensure-roles.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed:dev",
    "benchmark:x1": "ts-node src/benchmarkX1.ts",
    "qa10seasons": "ts-node src/qa10SeasonsDryRun.ts",
    "db:studio": "prisma studio",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.22.0",
    "@types/web-push": "^3.6.4",
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.0",
    "ioredis": "^5.11.1",
    "node-cron": "^4.2.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.7"
  }
}
